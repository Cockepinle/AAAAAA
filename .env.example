# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-new-for-production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=shopurpro
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=127.0.0.1
DB_PORT=5432
USE_SQLITE=False

# Security & Encryption
# Сгенерируйте новый ключ: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DATA_ENCRYPTION_KEY=your-encryption-key-here

# Email Configuration (для отправки уведомлений)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Application Settings
TIME_ZONE=Europe/Moscow
LANGUAGE_CODE=ru
USE_TZ=True

# Logging
LOG_LEVEL=INFO
